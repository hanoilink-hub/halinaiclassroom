{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HaLin AI Platform",
  "version": "0.6.2",
  "identifier": "com.hanoilink.halin-platform",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "HaLin AI Platform",
        "width": 820,
        "height": 540,
        "minWidth": 520,
        "minHeight": 360,
        "center": true,
        "transparent": false,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc://localhost wss: ws: https: http:; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../scripts/*": "scripts/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "frameworks": [],
      "minimumSystemVersion": "13.0"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZDRDA4N0EwRjQ5RkQ1REMKUldUYzFaLzBvSWZRL0IwRE1ocENOdm9DVXRQZjlTWjFDcTBpOXdOK3o5UjRZSUpLOUxyc2gvOTcK",
      "endpoints": [
        "https://github.com/hanoilink-hub/halinaiclassroom/releases/latest/download/latest.json"
      ]
    }
  }
}